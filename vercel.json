{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/alpilles", "destination": "/alpilles.html" },
    { "source": "/luberon", "destination": "/luberon.html" },
    { "source": "/chateauneuf", "destination": "/chateauneuf.html" },
    { "source": "/a-propos", "destination": "/a-propos.html" },
    { "source": "/contact", "destination": "/contact.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/style.css",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400" }]
    },
    {
      "source": "/main.js",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400" }]
    }
  ]
}
